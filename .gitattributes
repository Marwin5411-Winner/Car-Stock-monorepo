# Auto detect text files and perform LF normalization
* text=auto

# Force LF for shell scripts (critical for Docker/Linux containers)
*.sh text eol=lf
*.bash text eol=lf

# Force LF for Docker and config files
Dockerfile text eol=lf
docker-compose.yml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.prisma text eol=lf
*.conf text eol=lf

# Windows cmd.exe requires CRLF. LF-only .bat produces classic errors like
#   'tlocal' is not recognized  (from "setlocal" with a stray CR-less parse)
# Pack script also rewrites these to CRLF as a hard safety net for macOS pack hosts.
*.bat text eol=crlf
*.cmd text eol=crlf
# Portable Windows PowerShell helpers (shipped in the zip)
portable/windows/**/*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
