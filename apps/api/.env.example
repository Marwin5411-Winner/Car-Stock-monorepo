DATABASE_URL="postgresql://postgres:postgres@localhost:5432/car_stock?schema=public"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
PORT=3001
NODE_ENV=development

# Browser origin allowed by CORS (use same host:port as the UI in portable mode)
CORS_ORIGIN=http://localhost:5173

# --- Portable / single-process production ---
# Directory with built web UI (index.html). When set or when ./public exists, API serves the SPA.
# STATIC_DIR=./public
# Install root on Windows portable package (used by system updater in portable mode)
# VB_HOME=C:\VBeyond
# Updater backend: docker (default, sidecar) | portable (PowerShell + status file)
# UPDATER_MODE=docker
# Path to update-status.json (defaults depend on UPDATER_MODE)
# UPDATE_STATUS_PATH=

# System Updater (Docker sidecar)
UPDATER_URL=http://updater:9000
UPDATE_SECRET=change-this-to-a-random-secret

# PDF Generation (Puppeteer)
# CHROMIUM_PATH=/usr/bin/chromium  # Set in Docker; macOS uses Chrome automatically
# Windows portable example:
# CHROMIUM_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
