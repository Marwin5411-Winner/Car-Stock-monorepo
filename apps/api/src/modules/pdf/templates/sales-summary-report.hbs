<style>
  @page {
    size: A4 landscape;
    /* The base layout's .page already adds 10mm padding; a @page margin on top
       of that pushes the 297mm page past the printable area and clips the right
       columns. Keep margin 0 here and let .page provide the inset. */
    margin: 0;
  }
  body {
    font-family: 'Sarabun', sans-serif;
    font-size: 10px;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    /* Honour the column width %s and keep the table inside the A4 landscape
       width instead of letting wide content push it off the page. */
    table-layout: fixed;
  }
  th, td {
    border: 1px solid #ccc;
    padding: 2px 3px;
    vertical-align: top;
    /* Must set font-size on the cells directly: the base layout has a
       `th, td { font-size: 13px }` rule that otherwise overrides the table's
       inherited font and makes every value too wide for its column. */
    font-size: 8px;
    /* Wrap long values/headers within the cell rather than overflowing. */
    word-break: break-word;
    overflow-wrap: anywhere;
  }
  th {
    background-color: #f2f2f2;
    font-weight: bold;
    text-align: center;
    white-space: normal;
    color: #333;
    border-bottom: 2px solid #ddd;
  }
  .text-right { text-align: right; }
  .text-center { text-align: center; }
  .header-row th {
    background-color: #003366; /* Dark Blue */
    color: white;
    border: 1px solid #002244;
  }
  .sub-header-row th {
    background-color: #f0f0f0;
    color: #333;
    font-size: 9px;
  }
</style>

<div class="header">
  <div class="header-logo">
    <img src="{{header.logoBase64}}" alt="Logo">
  </div>
  <div class="header-info">
    <div class="company-name-wrapper">
      <div class="company-name">{{header.companyName}}</div>
      <div class="header-line"></div>
      <div class="header-address">
        {{header.address1}}<br>
        {{header.address2}}<br>
        {{header.phone}}
      </div>
    </div>
  </div>
</div>

<div class="document-title">สรุปยอดขายตามช่วงเวลา</div>

<div class="text-center" style="margin-bottom: 20px;">
  <strong>ช่วงเวลา:</strong> {{dateRange}}
  <div style="font-size: 9px; color: #666; margin-top: 2px;">หน่วย: บาท</div>
</div>

<div class="section">
  <table style="font-size: 8px; width: 100%; table-layout: fixed;">
    <colgroup>
      <col style="width: 3%"><col style="width: 8%"><col style="width: 7%"><col style="width: 6%"><col style="width: 3%"><col style="width: 3%"><col style="width: 5%"><col style="width: 3%"><col style="width: 5%"><col style="width: 5%"><col style="width: 5%"><col style="width: 5%"><col style="width: 6%"><col style="width: 5%"><col style="width: 6%"><col style="width: 5%"><col style="width: 5%"><col style="width: 3%"><col style="width: 3%"><col style="width: 3%"><col style="width: 6%">
    </colgroup>
    <thead>
      <tr class="header-row">
        <th rowspan="2" style="width: 3%">ลำดับ</th>
        <th style="width: 9%">ชื่อ - สกุล</th>
        <th style="width: 8%">เลขเครื่อง</th>
        <th rowspan="2" style="width: 5%">ราคารถ</th>
        <th rowspan="2" style="width: 4%">ส่วนลด<br>ตัวรถ</th>
        <th rowspan="2" style="width: 4%">ดอกเบี้ย</th>
        <th rowspan="2" style="width: 5%">เงินดาวน์</th>
        <th rowspan="2" style="width: 4%">ส่วนลด<br>ดาวน์</th>
        <th rowspan="2" style="width: 5%">คงเหลือ</th>
        <th style="width: 5%">ยอดจัด</th>
        <th style="width: 5%">ค่าคอม</th>
        <th rowspan="2" style="width: 5%">รวมรับเงิน</th>
        <th rowspan="2" style="width: 4%">วันที่ขาย</th>
        <th rowspan="2" style="width: 5%">ทะเบียน/พรบ<br>ขนส่ง</th>
        <th rowspan="2" style="width: 5%">ต้นทุน</th>
        <th rowspan="2" style="width: 5%">แคมเปญขาย</th>
        <th rowspan="2" style="width: 4%">กำไร<br>ขั้นต้น</th>
        <th rowspan="2" style="width: 4%">คอมฯ<br>พนักงาน</th>
        <th rowspan="2" style="width: 3%">ค่าใช้จ่าย<br>ขาย</th>
        <th rowspan="2" style="width: 3%">ค่าเบี้ย<br>ประกัน</th>
        <th rowspan="2" style="width: 5%">กำไรสุทธิ</th>
      </tr>
      <tr class="sub-header-row">
        <th>แบบรถ</th>
        <th>เลขคัซซี</th>
        <th>ซื้อไฟแนนซ์</th>
        <th>ไฟแนนซ์</th>
      </tr>
    </thead>
    <tbody>
      {{#each sales}}
      <tr>
        <td class="text-center">{{add @index 1}}</td>
        <td>
          {{customerName}}<br>
          <span style="color: #666;">{{vehicleModelName}}</span>
        </td>
        <td>
          {{engineNumber}}<br>
          <span style="color: #666;">{{chassisNumber}}</span>
        </td>
        <td class="text-right">{{formatInt totalAmount}}</td>
        <td class="text-right">{{formatInt discountAmount}}</td>
        <td class="text-right">{{formatInt interestCost}}</td>
        <td class="text-right">{{formatInt downPayment}}</td>
        <td class="text-right">{{formatInt downPaymentDiscount}}</td>
        <td class="text-right">{{formatInt remainingAmount}}</td>
        <td class="text-right">{{formatInt financeAmount}}</td>
        <td class="text-right">{{formatInt financeReturn}}</td>
        <td class="text-right">{{formatInt paidAmount}}</td>
        <td class="text-center" style="white-space: nowrap;">{{formatThaiDate saleDate 'numeric'}}</td>
        <td class="text-right">{{formatInt transportFee}}</td>
        <td class="text-right">{{formatInt totalCost}}</td>
        <td>{{campaignName}}</td>
        <td class="text-right">{{formatInt (subtract totalAmount totalCost)}}</td>
        <td class="text-right">{{formatInt salesCommission}}</td>
        <td class="text-right">{{formatInt salesExpense}}</td>
        <td class="text-right">{{formatInt insurancePremium}}</td>
        <td class="text-right">{{formatInt netProfit}}</td>
      </tr>
      {{/each}}
      <tr style="font-weight: bold; background-color: #eee;">
        <td colspan="3" class="text-right">รวมทั้งสิ้น ({{summary.totalSales}} คัน)</td>
        <td class="text-right">{{formatInt summary.totalAmount}}</td>
        <td class="text-right">{{formatInt summary.totalCarDiscount}}</td>
        <td class="text-right"></td>
        <td class="text-right">{{formatInt summary.totalDownPayment}}</td>
        <td class="text-right">{{formatInt summary.totalDownPaymentDiscount}}</td>
        <td class="text-right">{{formatInt summary.totalRemaining}}</td>
        <td class="text-right">{{formatInt summary.totalFinanceAmount}}</td>
        <td class="text-right">{{formatInt summary.totalFinanceReturn}}</td>
        <td class="text-right">{{formatInt summary.totalPaid}}</td>
        <td></td>
        <td class="text-right">{{formatInt summary.totalTransportFee}}</td>
        <td class="text-right">{{formatInt summary.totalCostSum}}</td>
        <td></td>
        <td class="text-right"></td>
        <td class="text-right">{{formatInt summary.totalSalesCommission}}</td>
        <td class="text-right">{{formatInt summary.totalSalesExpense}}</td>
        <td class="text-right">{{formatInt summary.totalInsurancePremium}}</td>
        <td class="text-right">{{formatInt summary.totalNetProfit}}</td>
      </tr>
    </tbody>
  </table>
</div>

<div style="page-break-inside: avoid; break-inside: avoid;">
  <table style="width: 65%; margin-top: 18px; font-size: 10px; border: none;">
    <tr>
      <td style="border: none; width: 18%;"><strong>ยอดมูลค่าขาย</strong></td>
      <td style="border: none; width: 17%;" class="text-right">{{formatCurrency summary.saleVatNet}}</td>
      <td style="border: none; width: 13%;"></td>
      <td style="border: none; width: 18%;"><strong>ยอดมูลค่าต้นทุน</strong></td>
      <td style="border: none; width: 17%;" class="text-right">{{formatCurrency summary.costVatNet}}</td>
    </tr>
    <tr>
      <td style="border: none;"><strong>ภาษีขาย</strong></td>
      <td style="border: none;" class="text-right">{{formatCurrency summary.saleVatAmount}}</td>
      <td style="border: none;"></td>
      <td style="border: none;"><strong>ภาษีซื้อ</strong></td>
      <td style="border: none;" class="text-right">{{formatCurrency summary.costVatAmount}}</td>
    </tr>
  </table>

  <div style="display: flex; justify-content: space-between; margin-top: 50px; font-size: 11px;">
    <div style="text-align: center; width: 45%;">
      ลงชื่อ.......................................................................ผู้จัดทำ
      <br><br>(.......................................................................)
    </div>
    <div style="text-align: center; width: 45%;">
      ลงชื่อ.......................................................................ผู้ตรวจสอบ
      <br><br>(.......................................................................)
    </div>
  </div>
</div>

<div class="footer" style="margin-top: 30px; text-align: right; font-size: 10px; color: #666;">
  พิมพ์เมื่อ: {{formatThaiDateWithDay (currentThaiDate)}}
</div>
