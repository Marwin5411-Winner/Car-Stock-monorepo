<div class="receipt-container">
    <!-- Header Section -->
    <div class="header-section">
        <div class="logo-box">
            <img src="{{header.logoBase64}}" alt="VB Innovation Logo" class="logo-img" />
        </div>
        <div class="company-details">
            <h1 class="company-name">{{header.companyName}}</h1>
            <p>{{header.address1}} {{header.address2}}</p>
            <p>{{header.phone}}</p>
        </div>
        <div class="original-label">ต้นฉบับ</div>
    </div>

    <!-- Main Table Wrapper for Rounded Border -->
    <div class="table-wrapper">
        <table class="main-receipt-table">
            <!-- Row 1: Customer Code, Title, Doc No -->
            <tr>
                <td class="label-cell" style="width: 15%;">รหัสลูกค้า</td>
                <td class="data-cell" style="width: 20%;">{{customerCode}}</td>
                <td class="title-cell" style="width: 30%;">ใบรับเงินชั่วคราว</td>
                <td class="label-cell label-no-left-border right-align" style="width: 15%;">เลขที่เอกสาร</td>
                <td class="data-cell" style="width: 20%;">{{receiptNumber}}</td>
            </tr>
            <!-- Row 2: Name, Date -->
            <tr>
                <td class="label-cell">ชื่อ - นามสกุล</td>
                <td class="data-cell" colspan="2" style="border-right: none;">{{customer.name}}</td>
                <td class="label-cell label-no-left-border right-align">วันที่</td>
                <td class="data-cell">{{formatThaiDate date 'short'}}</td>
            </tr>
            <!-- Row 3: Address, Phone, Contract No -->
            <tr>
                <td class="label-cell">ที่อยู่</td>
                <td class="data-cell" style="border-right: none;">{{customer.address}} {{customer.subdistrict}} {{customer.district}} {{customer.province}} {{customer.postalCode}}</td>
                <td class="data-cell label-no-left-border" style="border-right: none;"><strong>เบอร์โทร.</strong> {{customer.phone}}</td>
                <td class="label-cell label-no-left-border right-align">เลขที่สัญญา</td>
                <td class="data-cell">{{contractNumber}}</td>
            </tr>
            <!-- Items Header Row -->
            <tr class="items-header-row">
                <td class="items-header" colspan="3">รายการ</td>
                <td class="items-header amount-header" colspan="2">จำนวนเงิน</td>
            </tr>
            <!-- Items Body -->
            {{#each items}}
            <tr class="item-row">
                <td class="item-desc" colspan="3">{{this.description}}</td>
                <td class="item-amount" colspan="2">{{#if this.amount}}{{formatCurrency this.amount}}{{/if}}</td>
            </tr>
            {{/each}}
            <!-- Empty space for more items -->
            <tr class="item-row spacer-row">
                <td colspan="3">&nbsp;</td>
                <td colspan="2">&nbsp;</td>
            </tr>
            <!-- Totals Section -->
            <tr class="total-row">
                <td colspan="3" class="total-label-cell">ยอดชำระ</td>
                <td colspan="2" class="total-value-cell">{{formatCurrency paymentAmount}}</td>
            </tr>
            <tr class="total-row">
                <td colspan="3" class="total-label-cell">เบี้ยปรับล่าช้า/ค่าธน.</td>
                <td colspan="2" class="total-value-cell">{{formatCurrency lateFee}}</td>
            </tr>
            <tr class="total-row">
                <td colspan="3" class="total-label-cell">หักส่วนลด</td>
                <td colspan="2" class="total-value-cell">{{formatCurrency discount}}</td>
            </tr>
            <!-- Grand Total Row -->
            <tr class="grand-total-row">
                <td colspan="3" class="grand-total-label">จำนวนเงินที่ต้องชำระ</td>
                <td colspan="2" class="grand-total-value">{{formatCurrency totalAmount}}</td>
            </tr>
        </table>
    </div>

    <!-- Payment Method Table -->
    <div class="payment-method-wrapper">
        <table class="payment-method-table">
            <thead>
                <tr>
                    <th style="width: 14%;">ชำระโดย</th>
                    <th style="width: 26%;">ธนาคาร</th>
                    <th style="width: 18%;">สาขา</th>
                    <th style="width: 18%;">เลขที่เช็ค</th>
                    <th style="width: 10%;">ลงวันที่</th>
                    <th style="width: 14%;">จำนวนเงิน</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="method-label">{{#if paymentMethod.isCash}}☑{{else}}☐{{/if}} เงินสด</td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td class="amount-cell">{{#if paymentMethod.isCash}}{{formatCurrency paymentAmount}}{{/if}}</td>
                </tr>
                <tr>
                    <td class="method-label">{{#if paymentMethod.isCheque}}☑{{else}}☐{{/if}} เช็ค</td>
                    <td>{{#if paymentMethod.isCheque}}{{paymentMethod.bankName}}{{/if}}</td>
                    <td>{{#if paymentMethod.isCheque}}{{paymentMethod.branchName}}{{/if}}</td>
                    <td>{{#if paymentMethod.isCheque}}{{paymentMethod.chequeNumber}}{{/if}}</td>
                    <td>{{#if paymentMethod.isCheque}}{{paymentMethod.chequeDate}}{{/if}}</td>
                    <td class="amount-cell">{{#if paymentMethod.isCheque}}{{formatCurrency paymentMethod.chequeAmount}}{{/if}}</td>
                </tr>
                <tr>
                    <td class="method-label">{{#if paymentMethod.isTransfer}}☑{{else}}☐{{/if}} เงินโอน</td>
                    <td>{{#if paymentMethod.isTransfer}}{{paymentMethod.bankName}}{{/if}}</td>
                    <td>{{#if paymentMethod.isTransfer}}{{paymentMethod.branchName}}{{/if}}</td>
                    <td>{{#if paymentMethod.isTransfer}}{{paymentMethod.accountNumber}}{{/if}}</td>
                    <td>{{#if paymentMethod.isTransfer}}{{paymentMethod.transferDate}}{{/if}}</td>
                    <td class="amount-cell">{{#if paymentMethod.isTransfer}}{{formatCurrency paymentMethod.transferAmount}}{{/if}}</td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Signatures Section -->
    <div class="signatures-section">
        <div class="sig-row">
            <!-- Left Column: Signer -->
            <div class="sig-col-left">
                <div class="sig-item">
                    <span class="sig-label">ผู้รับเงิน</span>
                    <div class="sig-line"></div>
                </div>
            </div>
            <!-- Right Column: Date -->
            <div class="sig-col-right">
                <div class="sig-item">
                    <span class="sig-label">วันที่</span>
                    <div class="sig-line"></div>
                </div>
            </div>
        </div>

        <div class="sig-row">
             <div class="sig-col-left">
                <div class="sig-item">
                    <span class="sig-label">ผู้ตรวจสอบ</span>
                    <div class="sig-line"></div>
                </div>
            </div>
             <div class="sig-col-right">
                <div class="sig-item">
                    <span class="sig-label">วันที่</span>
                    <div class="sig-line"></div>
                </div>
            </div>
        </div>

        <div class="sig-row">
             <div class="sig-col-left">
                <div class="sig-item">
                    <span class="sig-label">ผู้จัดทํา</span>
                    <div class="sig-line"></div>
                </div>
            </div>
             <div class="sig-col-right">
                <!-- Empty for last row -->
            </div>
        </div>
    </div>
</div>

<style>
    /* ============================================
       Temporary Receipt - Recreated & Refined
       Paper: 9in × 5.5in (Dot Matrix continuous form, pre-printed)
       ============================================ */

    @page {
        size: 9in 5.5in;
        margin: 3mm;
    }

    /* Keep the whole receipt on a single page; if content is too tall the
       browser will scale rather than paginate. The signature block was
       overflowing to a second page for customers with long addresses. */
    html, body {
        margin: 0;
        padding: 0;
    }

    .receipt-container {
        font-family: 'Kanit', sans-serif;
        color: #000;
        padding: 0;
        margin: 0;
        font-size: 10px;
        line-height: 1.2;
        position: relative;
    }

    /* Header Section */
    .header-section {
        display: flex;
        align-items: flex-start;
        margin-bottom: 0;
        position: relative;
    }

    .logo-box {
        width: 55px;
        margin-right: 15px;
    }

    .logo-img {
        width: 55px;
        height: auto;
    }

    .company-details {
        flex: 1;
        padding-top: 2px;
    }

    .company-name {
        font-size: 15px;
        font-weight: bold;
        margin: 0 0 2px 0;
    }

    .company-details p {
        font-size: 10px;
        margin: 0;
        line-height: 1.35;
    }

    .original-label {
        width: 80px;
        text-align: center;
        color: red; 
        font-size: 14px;
        font-weight: bold;
        padding-top: 2px;
    }

    /* Table Wrapper for Rounded Corners and Thick Border */
    .table-wrapper {
        border: 2px solid #000; /* Outer thick border */
        border-radius: 6px;
        overflow: hidden;
        margin-bottom: 3px;
    }

    .main-receipt-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 11px;
        border-style: hidden; 
    }

    .main-receipt-table td {
        border: 1px solid #000;
        padding: 1px 3px;
        vertical-align: middle;
    }

    /* Helper Classes */
    .label-cell {
        background-color: #fff;
        text-align: left;
    }

    .data-cell {
        background-color: #fff;
        text-align: left;
    }

    .right-align {
        text-align: right;
    }

    /* Remove left border for specific cells to merge visually with valid previous cell */
    .label-no-left-border {
        border-left: none !important;
    }

    .title-cell {
        text-align: center;
        font-size: 18px;
        font-weight: bold;
        color: red; 
        border-left: 1px solid #000;
        border-right: 1px solid #000;
    }

    /* Items Header */
    .items-header-row td {
        background-color: #fff;
        font-weight: normal;
        padding-top: 3px;
        padding-bottom: 3px;
        border-bottom: none;
    }
    
    .items-header {
        text-align: left;
        padding-left: 15px;
    }
    
    .amount-header {
        text-align: center;
        border-left: 1px solid #000;
    }

    /* Item Rows */
    .item-row td {
        border-top: none;
        border-bottom: none;
        padding: 2px 15px;
    }

    .item-desc {
        text-align: left;
    }

    .item-amount {
        text-align: right;
        border-left: 1px solid #000;
    }

    .spacer-row td {
        height: 20px; /* minimal filler — original 80px caused signature overflow */
    }

    /* Totals Section */
    .total-row td {
        border-top: none;
        border-bottom: none;
        padding: 1px 15px;
    }

    .total-label-cell {
        text-align: right;
        padding-right: 10px;
        border-right: none !important;
        border-left: 2px solid #000 !important; /* Re-establish left border for totals area if needed, but wrapper handles it mainly. 
            Actually, the table td border handles it. Let's ensure the vertical line is continuous. */
    }

    .total-value-cell {
        text-align: right;
        border-left: 1px solid #000 !important;
        border-right: none !important; 
    }

    /* Grand Total Row */
    .grand-total-row td {
        border-top: 1px solid #000;
        padding: 3px 15px;
    }

    .grand-total-label {
        text-align: right;
        padding-right: 10px;
        font-weight: bold;
        border-right: none !important;
    }

    .grand-total-value {
        text-align: right;
        font-weight: bold;
        border-left: 1px solid #000 !important;
    }

    /* Payment Method Table */
    .payment-method-wrapper {
        margin-top: 2px;
        margin-bottom: 2px;
    }

    .payment-method-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 10px;
        border: 1px solid #000;
    }

    .payment-method-table th,
    .payment-method-table td {
        border: 1px solid #000;
        padding: 1px 4px;
        vertical-align: middle;
        text-align: center;
        height: 14px;
    }

    .payment-method-table th {
        background-color: #fff;
        font-weight: bold;
    }

    .payment-method-table .method-label {
        text-align: left;
        padding-left: 6px;
    }

    .payment-method-table .amount-cell {
        text-align: right;
        padding-right: 6px;
    }

    /* Signatures Section */
    .signatures-section {
        margin-top: 3px;
        font-size: 10px;
        page-break-inside: avoid; /* keep all sig rows on the same page */
    }

    .sig-row {
        display: flex;
        justify-content: flex-start;
        align-items: center;
        margin-bottom: 3px;
        position: relative;
    }

    .sig-col-left {
        width: 45%;
    }
    
    .sig-col-right {
        width: 40%;
        margin-left: 5%;
    }

    .sig-item {
        display: flex;
        align-items: flex-end;
    }

    .sig-label {
        font-weight: bold;
        margin-right: 10px;
        min-width: 60px;
    }

    .sig-line {
        flex: 1;
        border-bottom: 1px dotted #000;
        height: 1px;
        margin-bottom: 4px;
    }
    
    .sig-suffix-box {
        position: absolute;
        right: 0;
        top: 0;
    }
    
    .sig-suffix {
        font-weight: bold;
    }

</style>
