<!-- ใบปล่อยรถ/ใบรับรถ (Delivery Receipt) -->
<div class="page">
  {{> header}}

  <h1 class="document-title">ใบปล่อยรถ/ใบรับรถ</h1>

  {{#if deliveryDate}}
  <div class="date-display" style="text-align: right; margin-bottom: 10px;">
    วันที่ {{deliveryDate}}
  </div>
  {{/if}}

  <div class="content" style="margin-top: 20px; line-height: 1.6;">
    <p class="indent">
      ข้าพเจ้า <strong>{{customer.name}}</strong>
      บ้านเลขที่ {{safe customer.address "-"}}
      ถนน {{safe customer.street "-"}}
      ตำบล/แขวง {{safe customer.subdistrict "-"}}
      อำเภอ/เขต {{safe customer.district "-"}}
      จังหวัด {{safe customer.province "-"}}
      รหัสไปรษณีย์ {{safe customer.postalCode "-"}}
      โทรติดต่อ {{formatPhone customer.phone}}
      ได้รับรถยนต์ไฟฟ้า ยี่ห้อ <strong>{{car.brand}}</strong>
      เลขเครื่องยนต์ {{safe car.engineNo "-"}}
      เลขตัวแชชซีส {{safe car.chassisNo "-"}}
      สี {{safe car.color "-"}}
    </p>

    <p class="indent" style="margin-top: 15px;">
      จากทาง{{header.companyName}} โดยข้าพเจ้าได้ตรวจดูรถยนต์คันดังกล่าวแล้ว
      เป็นรถใหม่ ไม่มีการใช้งานมาก่อน สภาพสมบูรณ์ พร้อมด้วยของแถมที่ได้ตกลงในเงื่อนไขการซื้อขาย
    </p>
  </div>

  {{#if items.length}}
  <div class="items-section" style="margin-top: 25px;">
    <h3 style="font-size: 14px; font-weight: bold; margin-bottom: 8px;">รายการที่ต้องจ่าย</h3>
    <table style="width: 100%; border-collapse: collapse; font-size: 13px;">
      <thead>
        <tr style="background-color: #f3f4f6; border-bottom: 1px solid #000;">
          <th style="text-align: left; padding: 6px 10px; border: 1px solid #000;">รายการ</th>
          <th style="text-align: right; padding: 6px 10px; border: 1px solid #000; width: 30%;">จำนวนเงิน (บาท)</th>
        </tr>
      </thead>
      <tbody>
        {{#each items}}
        <tr>
          <td style="padding: 5px 10px; border: 1px solid #000;">{{this.description}}</td>
          <td style="padding: 5px 10px; border: 1px solid #000; text-align: right;">{{formatCurrency this.amount}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{/if}}

  <div class="signatures" style="margin-top: 50px;">
    <div class="signature-box">
      <div class="signature-line"></div>
      <div class="signature-label">ลูกค้า/ผู้รับรถ</div>
    </div>
    <div class="signature-box">
      <div class="signature-line"></div>
      <div class="signature-label">ที่ปรึกษาการขาย</div>
    </div>
  </div>
</div>
