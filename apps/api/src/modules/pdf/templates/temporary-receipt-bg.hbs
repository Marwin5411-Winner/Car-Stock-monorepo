{{!--
  ใบรับเงินชั่วคราว — DATA-ONLY OVERLAY สำหรับฟอร์ม SIAMK (Dot Matrix 9×5.5 นิ้ว)
  ====================================================================
  v1.0.40 (recalibrated 2026-06-19 จาก temp-receipt-preview "Fix" — ทุก cell ขยับ
           ตามฟอร์มจริงรอบใหม่; totals ย้ายมา left 137mm; เพิ่ม "จำนวนเงิน(ตัวอักษร)"
           และ "เลขบัญชีธนาคาร" ฝั่งซ้าย เหนือจำนวนเงินตัวอักษร)

  กระดาษ: 9in × 5.5in แนวนอน (228.6 × 139.7 mm)
  ฟอร์ม SIAMK 1 แผ่น = 1 ใบ

  โครงสร้างฟอร์มจริง (verified จาก CamScanner):
  ┌─ HEADER ───────────────────────────────────────────────────────────┐
  │  SIAMK logo + ที่อยู่บริษัท                  [CUST-XXXX] (นอก box) │
  ├─ นอก box (ขวา 4 cells — ตรงกับ 3 แถวของ box) ──────────────────────┤
  │  ต้นฉบับ → RCPT                                [RCPT-XXXX]       │
  │  วันที่   → 4 มิ.ย. 2569                                          │
  ├─ BOX บน (3 แถว × 1 cell เต็มความกว้าง) ───────┬─ นอก box (ขวา) ┤
  │  แถว 1: ชื่อ-นามสกุล   → นาง ศรีนภา ช่างกี        │ เลขที่สัญญา    │
  │  แถว 2: รถ             → ค่างวดรถยนต์ - CHERY... │                │
  │  แถว 3: ที่อยู่         → 142 หมู่ 7 ...          │ เบอร์โทรศัพท์  │
  ├─ BOX ล่าง ──────────────────────────────────────────────────────┤
  │  รายการ (cell สูง)        │ จำนวนเงิน (4 cell ย่อย)              │
  │  [เลขบัญชีธนาคาร]          │ ยอดชำระ / เบียปรับ / ส่วนลด / ยอดสุทธิ │
  │  (จำนวนเงินตัวอักษร)        │                                       │
  ├─ Signature lines ────────────────────────────────────────────────┤
  │  ผู้รับเงิน .......... วันที่ ........ ชำระโดย ........               │
  └──────────────────────────────────────────────────────────────────┘

  ── วิธี calibrate (ปรับตำแหน่ง) ──────────────────────────────
  • เลื่อน "ทั้งแผ่น" พร้อมกัน  → แก้  --offset-x / --offset-y  ที่ :root
  • เลื่อน "เฉพาะช่อง"          → แก้ค่า top / left ของ .f-xxx แต่ละตัว
  • ขนาดตัวอักษร               → แก้ --fs
  ค่าทั้งหมดเป็นมิลลิเมตร (mm) นับจากมุมซ้ายบนของกระดาษ
--}}

<div class="ovl">
  <!-- ════════ HEADER — CUST-XXXX (นอก box, ใต้ SIAMK header) ════════ -->
  <div class="f f-cust-code">{{customerCode}}</div>

  <!-- ════════ นอก BOX (ขวา 4 cells — สอดคล้องกับ 3 แถวของ box + header) ════════ -->
  <!-- header row: ต้นฉบับ -->
  <div class="f f-receipt-no">{{receiptNumber}}</div>
  <!-- header row: วันที่ -->
  <div class="f f-date">{{formatThaiDate date 'short'}}</div>
  <!-- แถว 1 ของ box: เลขที่สัญญา -->
  <div class="f f-contract">{{contractNumber}}</div>
  <!-- แถว 3 ของ box: เบอร์โทรศัพท์ -->
  <div class="f f-phone">{{customer.phone}}</div>

  <!-- ════════ BOX บน (3 แถว × 1 cell เต็มความกว้าง) ════════ -->
  <!-- แถว 1: ชื่อ-นามสกุล -->
  <div class="f f-cust-name">{{customer.name}}</div>
  <!-- แถว 2: ที่อยู่ -->
  <div class="f f-cust-addr">{{customer.address}} {{customer.subdistrict}} {{customer.district}} {{customer.province}} {{customer.postalCode}}</div>

  <!-- ════════ BOX ล่าง — cell "รายการ" (ซ้าย, cell สูง) ════════ -->
  <!-- รายการค่าใช้จ่าย (items array) — เอามาไว้ใน cell "รายการ" ด้านล่างที่อยู่ -->
  <div class="f f-items">
    {{#each items}}
    <div class="item-block">
      <div class="item-desc">{{this.description}}</div>
      {{#if this.amount}}
      <div class="item-amt">{{formatCurrency this.amount false}}</div>
      {{/if}}
    </div>
    {{/each}}
  </div>

  <!-- ════════ เลขบัญชีธนาคาร (ขวาของ "ชำระโดย" บนบรรทัด signature) ════════ -->
  {{#if bankAccount.accountNumber}}
  <div class="f f-bank-account">
    <div>{{bankAccount.bankName}} เลขที่บัญชี {{bankAccount.accountNumber}}</div>
    {{#if bankAccount.accountName}}<div>ชื่อบัญชี {{bankAccount.accountName}}</div>{{/if}}
  </div>
  {{/if}}

  <!-- ════════ BOX ล่าง — cell "จำนวนเงิน" (ขวา, 4 cell ย่อย) ════════ -->
  <div class="f f-total-paid">{{formatCurrency paymentAmount false}}</div>
  <div class="f f-total-late">{{formatCurrency lateFee false}}</div>
  <div class="f f-total-discount">{{formatCurrency discount false}}</div>
  <div class="f f-grand-total">{{formatCurrency totalAmount false}}</div>

  <!-- ════════ จำนวนเงิน (ตัวอักษร) — Y เท่ากับ grand-total, X เท่ากับ items ════════ -->
  {{#if totalAmountText}}
  <div class="f f-amount-text">({{totalAmountText}})</div>
  {{/if}}

  <!-- ════════ Signature lines (ล่างสุดของฟอร์ม) ════════ -->
  <!-- "ชำระโดย" อยู่ท้ายบรรทัด "ผู้รับเงิน ... วันที่ ... ชำระโดย ..." -->
  {{#if paymentMethodLabel}}
  <div class="f f-pay-method">{{paymentMethodLabel}}</div>
  {{/if}}
</div>

<style>
  :root {
    /* === global calibration (เลื่อนทั้งแผ่น) === */
    --offset-x: 0mm;
    --offset-y: 0mm;

    /* === ขนาดตัวอักษร === */
    --fs: 12px;
  }

  @page {
    size: 9in 5.5in;
    margin: 0;
  }

  html, body {
    margin: 0;
    padding: 0;
    overflow: hidden;
  }

  .ovl {
    position: relative;
    width: 228.6mm;
    height: 139.7mm;
    font-family: 'Kanit', sans-serif;
    color: #000;
    font-size: var(--fs);
    line-height: 1.2;
    transform: translate(var(--offset-x), var(--offset-y));
  }

  .f {
    position: absolute;
    white-space: nowrap;
  }

  /* ════════════════════════════════════════════════════════════════
     CUST-XXXX — แถวเดียวกับ "ชื่อ-นามสกุล" (ขวาของชื่อ)
     ════════════════════════════════════════════════════════════════ */
  .f-cust-code {
    top: 37mm; left: 20mm;
  }

  /* ════════════════════════════════════════════════════════════════
     นอก BOX (ขวา) — RCPT, วันที่, เลขที่สัญญา, โทร.
     ════════════════════════════════════════════════════════════════ */
  .f-receipt-no {
    top: 30mm; left: 135mm; width: 50mm; text-align: right;
  }
  .f-date {
    top: 36mm; left: 160mm; width: 50mm; text-align: left;
  }
  .f-contract {
    top: 44mm; left: 154mm; width: 50mm; text-align: left;
  }
  .f-phone {
    top: 50mm; left: 109mm; width: 50mm; text-align: right;
  }

  /* ════════════════════════════════════════════════════════════════
     BOX บน (ชื่อ / ที่อยู่)
     ════════════════════════════════════════════════════════════════ */
  .f-cust-name {
    top: 43mm; left: 26mm;
  }
  .f-cust-addr {
    top: 51mm; left: 26mm; max-width: 130mm; white-space: normal;
  }

  /* ════════════════════════════════════════════════════════════════
     BOX ล่าง — cell "รายการ" (ซ้าย, cell สูง — ใส่รายการค่าใช้จ่าย)
     ════════════════════════════════════════════════════════════════ */
  .f-items {
    top: 60mm;
    left: 27mm;
    width: 130mm;
    line-height: 1.3;
  }
  /* แต่ละรายการ: description (บน) + amount (ใต้ ต่อกันเลย ไม่ชิดขวา) */
  .item-block {
    margin-bottom: 1mm;
  }
  .item-desc { }
  .item-amt  {
    /* default: ต่อกับ description เลย — ไม่ชิดขวา */
    white-space: nowrap;
    font-size: calc(var(--fs) - 1px);
    color: #333;
  }

  /* ════════════════════════════════════════════════════════════════
     เลขบัญชีธนาคาร — ขวาของ "ชำระโดย" บนบรรทัด signature เดียวกัน
     ════════════════════════════════════════════════════════════════ */
  .f-bank-account {
    top: 118mm;
    left: 152mm;
    width: 55mm;
    line-height: 2;
    font-size: calc(var(--fs) - 1px);
    white-space: normal;
  }

  /* ════════════════════════════════════════════════════════════════
     BOX ล่าง — cell "จำนวนเงิน" (ขวา, 4 cell ย่อย)
     ════════════════════════════════════════════════════════════════ */
  .f-total-paid,
  .f-total-late,
  .f-total-discount,
  .f-grand-total {
    left: 137mm; width: 50mm; text-align: right;
  }
  .f-total-paid     { top: 77mm; }
  .f-total-late     { top: 83mm; }
  .f-total-discount { top: 90mm; }
  .f-grand-total    { top: 107.5mm; font-weight: bold; }

  /* ════════════════════════════════════════════════════════════════
     จำนวนเงิน (ตัวอักษร) — Y เดียวกับ .f-grand-total | X เดียวกับ .f-items
     ════════════════════════════════════════════════════════════════ */
  .f-amount-text {
    top: 108mm;
    left: 15mm;
    font-weight: bold;
  }

  /* ════════════════════════════════════════════════════════════════
     Signature lines — "ชำระโดย" อยู่ท้ายบรรทัด
     ════════════════════════════════════════════════════════════════ */
  .f-pay-method {
    top: 119mm;
    left: 135mm;
    width: 55mm;
    text-align: left;
  }
</style>
