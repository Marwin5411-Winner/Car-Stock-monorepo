{{! Data-only overlay for pre-printed vehicle card form.
    Same grid geometry as vehicle-card.hbs so values land on pre-printed cells.
    No title, borders, headings, or row labels — values only. }}
<div class="page">
  <style>
    .page {
      font-family: 'Sarabun', 'Kanit', sans-serif;
      font-size: 9px;
      padding: 0;
      color: #000;
      position: relative;
    }
    .page * {
      color: #000 !important;
      background: transparent !important;
      box-sizing: border-box;
    }
    .page table {
      width: 100%;
      table-layout: fixed;
      border-collapse: collapse;
      border: none !important;
    }
    .page th, .page td {
      border: none !important;
      padding: 2px;
      vertical-align: middle;
      line-height: 1.2;
      height: 14px;
    }
    .page .mt-neg {
      margin-top: -1px;
    }
    @media print {
      .page {
        padding: 5px !important;
        margin: 0 !important;
        page-break-after: always !important;
        page-break-inside: avoid !important;
      }
    }
  </style>

  {{! Spacer row matches full-card header height; values land on the data row }}
  <table>
    <tr>
      <td style="width: 14%;"></td>
      <td style="width: 16%;"></td>
      <td style="width: 16%;"></td>
      <td style="width: 16%;"></td>
      <td style="width: 10%;"></td>
      <td style="width: 14%;"></td>
      <td style="width: 14%;"></td>
    </tr>
    <tr>
      <td></td>
      <td style="text-align: center;">{{car.model}}{{#if car.variant}} {{car.variant}}{{/if}}</td>
      <td style="text-align: center;">{{car.engineNo}}</td>
      <td style="text-align: center;">{{car.chassisNo}}</td>
      <td style="text-align: center;">{{car.color}}</td>
      <td></td>
      <td style="text-align: center; font-weight: bold;">{{stockNumber}}</td>
    </tr>
  </table>

  {{#if car.motorNumbers}}
  <table class="mt-neg">
    <tr>
      <td style="width: 16%;"></td>
      <td style="text-align: center;">{{car.motorNumbers}}</td>
    </tr>
  </table>
  {{/if}}

  {{! Date header spacer + order date value only }}
  <table class="mt-neg">
    <tr>
      <td style="width: 25%;"></td>
      <td style="width: 25%;"></td>
      <td style="width: 25%;"></td>
      <td style="width: 25%;"></td>
    </tr>
    <tr>
      <td style="text-align: center;">{{orderDate}}</td>
      <td></td>
      {{! วันที่ขาย stays blank — customer fills it in by hand at sale time }}
      <td></td>
      <td></td>
    </tr>
  </table>

  <table class="mt-neg">
    <colgroup>
      <col style="width: 5%;">
      <col style="width: 19%;">
      <col style="width: 12%;">
      <col style="width: 3%;">
      <col style="width: 8%;">
      <col style="width: 19%;">
      <col style="width: 12%;">
      <col style="width: 11%;">
      <col style="width: 11%;">
    </colgroup>

    {{! Main table header spacer }}
    <tr>
      <td></td>
      <td></td>
      <td colspan="2"></td>
      <td></td>
      <td></td>
      <td></td>
      <td></td>
      <td></td>
    </tr>

    {{! Row 1: ราคาก่อน VAT values }}
    <tr>
      <td></td>
      <td></td>
      <td style="text-align: right;">{{costs.beforeVatInt}}</td>
      <td style="text-align: center;">{{costs.beforeVatDec}}</td>
      <td></td>
      <td></td>
      <td></td>
      <td></td>
      <td></td>
    </tr>

    {{! Row 2: VAT 7% values }}
    <tr>
      <td></td>
      <td></td>
      <td style="text-align: right;">{{costs.vatAmountInt}}</td>
      <td style="text-align: center;">{{costs.vatAmountDec}}</td>
      <td></td>
      <td></td>
      <td></td>
      <td></td>
      <td></td>
    </tr>

    {{! Rows 3–5: empty spacers }}
    <tr>
      <td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td>
    </tr>
    <tr>
      <td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td>
    </tr>
    <tr>
      <td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td>
    </tr>

    {{! Row 6: total with VAT }}
    <tr>
      <td colspan="2"></td>
      <td style="text-align: right; font-weight: bold;">{{costs.totalWithVatInt}}</td>
      <td style="text-align: center; font-weight: bold;">{{costs.totalWithVatDec}}</td>
      <td></td>
      <td></td>
      <td></td>
      <td></td>
      <td></td>
    </tr>

    {{! Remaining form rows: empty spacers to preserve vertical alignment }}
    <tr>
      <td colspan="5"></td>
      <td></td>
      <td></td>
      <td></td>
      <td></td>
    </tr>
    <tr>
      <td colspan="5"></td>
      <td></td>
      <td></td>
      <td></td>
      <td></td>
    </tr>
    <tr>
      <td colspan="2"></td>
      <td colspan="2"></td>
      <td></td>
      <td></td>
      <td></td>
      <td></td>
      <td></td>
    </tr>
    <tr>
      <td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td>
    </tr>
    <tr>
      <td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td>
    </tr>
    <tr>
      <td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td>
    </tr>
    <tr>
      <td colspan="5"></td>
      <td></td>
      <td></td>
      <td></td>
      <td></td>
    </tr>
    <tr>
      <td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td>
    </tr>
    <tr>
      <td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td>
    </tr>
    <tr>
      <td></td>
      <td></td>
      <td></td>
      <td></td>
      <td></td>
      <td colspan="4" rowspan="2"></td>
    </tr>
    <tr>
      <td></td><td></td><td></td><td></td><td></td>
    </tr>
    <tr>
      <td colspan="2"></td>
      <td></td>
      <td></td>
      <td></td>
      <td colspan="4" rowspan="2"></td>
    </tr>
    <tr>
      <td colspan="5"></td>
    </tr>
  </table>
</div>
