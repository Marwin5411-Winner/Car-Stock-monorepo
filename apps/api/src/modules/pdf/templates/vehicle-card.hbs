<div class="page">
  <style>
    /*
      Vehicle card (ปกติ) — paper 27×21 cm
      Margins: top 10mm / bottom 6mm / L-R 10mm → content 25cm × 194mm
      Height budget (~184mm used + ~10mm buffer):
        title 5mm + 24×row-h-7 @ 6.8mm + 4×row-h-4-5 @ 4mm
      Column anchors (cm from left of content):
        0 | 4.4 | 8.7 | 13.0 | 17.2 | 19.8 | 22.4 | 25
        รหัสสี / พนักงานขาย / จำนวนเงิน align at 17.2
    */

    /* ── Page shell ─────────────────────────────────────────── */
    .page {
      font-family: 'Sarabun', 'Kanit', sans-serif;
      font-size: 9px;
      color: #000;
      width: 25cm;
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      overflow: visible; /* hidden clips the outer right border at 25cm */
    }
    .page * {
      color: #000 !important;
      background: transparent !important;
      box-sizing: border-box;
    }
    .page .title {
      text-align: center;
      font-weight: bold;
      font-size: 13px;
      line-height: 4mm;
      height: 5mm;
      max-height: 5mm;
      margin: 0;
      padding: 0;
      overflow: hidden;
    }
    .page .checkbox {
      display: inline-block;
      width: 8px;
      height: 8px;
      border: 1px solid #000;
      margin-right: 2px;
      vertical-align: middle;
    }
    .page .mt-neg {
      margin-top: -1px !important; /* stack tables so borders share one line */
    }

    /* ── Tables (base) ──────────────────────────────────────── */
    .page table {
      width: 25cm; /* fixed cm — % drifts between stacked tables */
      max-width: 25cm;
      table-layout: fixed;
      border-collapse: collapse;
      border-spacing: 0;
      border: 1px solid #000;
      margin: 0 !important; /* override wrapHtml base margin: 10px 0 */
    }
    .page table + table {
      margin-top: -1px !important;
    }
    .page th,
    .page td {
      border: 1px solid #000;
      padding: 0 2px;
      vertical-align: middle;
      line-height: 1.1;
      overflow: hidden;
    }

    /*
      card-main: outer right comes from cells (recv-total / summary-span),
      not the <table> edge — avoids a double line on the footer.
    */
    .page table.card-main {
      border-left: 1px solid #000 !important;
      border-right: none !important;
    }
    /*
      Outer left edge on main-table rows only.
      Direct-child selectors only — never match nested .inner-table cells
      (that leak painted a short bar beside สรุป/หัก).
      Browsers insert <tbody>, so target > tbody > tr.
    */
    .page .card-main > tbody > tr > th:first-child,
    .page .card-main > tbody > tr > td:first-child {
      border-left: 1px solid #000 !important;
    }

    /* ── Row heights ────────────────────────────────────────── */
    /* Default body row (~7mm, slightly under to stay on one page) */
    .page table tr.row-h-7 {
      height: 6.8mm;
      max-height: 6.8mm;
    }
    .page table tr.row-h-7 > th,
    .page table tr.row-h-7 > td {
      height: 6.8mm;
      max-height: 6.8mm;
      font-size: 8.5px;
      line-height: 6.2mm;
      padding-top: 0;
      padding-bottom: 0;
      overflow: hidden;
    }
    /* Footer note spacers under หมายเหตุ */
    .page table tr.row-h-4-5 {
      height: 4mm;
      max-height: 4mm;
    }
    .page table tr.row-h-4-5 > th,
    .page table tr.row-h-4-5 > td {
      height: 4mm;
      max-height: 4mm;
      padding: 0 2px;
      line-height: 3.6mm;
      font-size: 8px;
      overflow: hidden;
    }

    /* ── Header / dates ─────────────────────────────────────── */
    .page .card-top-unified th {
      text-align: center;
    }
    /* Merge วันที่รับรถ + วันที่ขาย (no vertical rule between) */
    .page .card-dates td.date-sale {
      border-left: none !important;
    }
    .page .card-dates td.date-receive {
      border-right: none !important;
    }

    /* ── Sale column labels ─────────────────────────────────── */
    .page td.sale-label {
      padding-left: 12px !important;
    }

    /* ── Footer: รวมรายรับ / หมายเหตุ / สรุป-หัก ──────────────── */
    /* รวมรายรับทั้งสิ้น — rowspan 3, flush with left "รวม" */
    .page td.recv-total {
      vertical-align: middle !important;
      text-align: center;
      font-size: 8.5px;
      white-space: nowrap;
      overflow: hidden;
      border-bottom: none !important;
      border-right: 1px solid #000 !important;
    }
    /* หมายเหตุ — two lines inside one row-h-7 */
    .page td.note-cell {
      padding: 0 2px !important;
      vertical-align: top !important;
      font-size: 7.5px !important;
      line-height: 3.2mm !important;
    }
    .page td.note-cell div {
      margin: 0;
      padding: 0;
      line-height: 3.2mm;
      font-size: 7.5px;
      overflow: hidden;
      white-space: nowrap;
    }
    /*
      สรุป/หัก span (right of หมายเหตุ):
      left rule = note-cell border-right only
      top open into recv-total above
      right = sole outer edge (table has no border-right)
    */
    .page td.summary-span {
      vertical-align: top !important;
      padding: 2px 2px 2px 7mm !important;
      border-top: none !important;
      border-left: none !important;
      border-right: 1px solid #000 !important;
      overflow: hidden;
    }
    /* Empty left footer rows: keep the vertical divider into summary */
    .page .card-main tr.row-h-4-5 > td {
      border-right: 1px solid #000 !important;
    }

    /*
      Nested summary labels — grid lines off; dotted fill only.
      Scoped under .card-main so outer cell borders cannot win on specificity.
      border-collapse: separate avoids Chromium PDF paint artifacts.
    */
    .page .card-main .inner-table {
      width: 100%;
      max-width: 100%;
      table-layout: fixed;
      border-collapse: separate;
      border-spacing: 0;
      border: none !important;
      margin: 0 !important;
    }
    .page .card-main .inner-table th,
    .page .card-main .inner-table td {
      border: none !important;
      outline: none !important;
      box-shadow: none !important;
      padding: 0 1px !important;
      height: auto !important;
      max-height: none !important;
      line-height: 1.15 !important;
      font-size: 7.5px !important;
    }
    .page .card-main .inner-table td.dotted-line {
      border: none !important;
      border-bottom: 1px dotted #000 !important;
    }

    /* ── Print ──────────────────────────────────────────────── */
    @media print {
      .page {
        padding: 0 !important;
        margin: 0 !important;
        page-break-after: auto !important;
        page-break-inside: avoid !important;
      }
    }
  </style>

  <h1 class="title">การ์ดรายละเอียดรถยนต์</h1>

