<div class="page">
  <style>
    /*
      Vehicle card (ปกติ)
      Paper content width 25cm (27 − 1cm L/R)
      Row heights: default 7mm
        — except รวมรายรับทั้งสิ้น (spans left rows 3–4)
        — except สรุป/หัก (right span to bottom)
        — except bottom 4 rows @ 4.5mm
    */
    .page {
      font-family: 'Sarabun', 'Kanit', sans-serif;
      font-size: 9px;
      padding: 0;
      color: #000;
      width: 25cm;
      box-sizing: border-box;
    }
    .page * {
      color: #000 !important;
      background: transparent !important;
      box-sizing: border-box;
    }
    .page table {
      width: 100%;
      table-layout: fixed;
      border-collapse: collapse;
      border: 1px solid #000;
      margin: 0 !important; /* kill base HTML table margin: 10px 0 */
      border-spacing: 0;
    }
    /* Stack top tables flush — no gap, share one border line */
    .page table + table {
      margin-top: -1px !important;
    }
    .page th, .page td {
      border: 1px solid #000;
      padding: 0 2px;
      vertical-align: middle;
      line-height: 1.15;
      overflow: hidden;
    }
    /* Default: every body row 7mm */
    .page table tr.row-h-7,
    .page table tr.row-h-7 > th,
    .page table tr.row-h-7 > td {
      height: 7mm;
      max-height: 7mm;
      font-size: 8.5px;
      line-height: 6.5mm;
    }
    /* รวมรายการทั้งสิ้น */
    .page table tr.row-h-14,
    .page table tr.row-h-14 > th,
    .page table tr.row-h-14 > td {
      height: 14mm;
      max-height: 14mm;
      font-size: 9px;
      line-height: 1.2;
    }
    /* Bottom 4 rows */
    .page table tr.row-h-4-5,
    .page table tr.row-h-4-5 > th,
    .page table tr.row-h-4-5 > td {
      height: 4.5mm;
      max-height: 4.5mm;
      padding: 0 2px;
      line-height: 4.2mm;
      font-size: 8px;
      overflow: hidden;
    }
    /* รวมรายรับทั้งสิ้น — not forced to 7mm (spans 2×7mm left rows) */
    .page td.recv-total {
      vertical-align: middle !important;
      font-size: 8.5px;
      white-space: nowrap;
    }
    /* สรุป/หัก — spans รวม 7mm + footer 7mm + 4×4.5mm */
    .page td.summary-span {
      vertical-align: top !important;
      padding: 3px !important;
    }
    .page .title {
      text-align: center;
      font-weight: bold;
      font-size: 14px;
      margin-bottom: 3px;
      margin-top: 0;
    }
    .page .checkbox {
      display: inline-block;
      width: 8px;
      height: 8px;
      border: 1px solid #000;
      margin-right: 2px;
      vertical-align: middle;
    }
    .page .inner-table {
      border: none !important;
      width: 100%;
    }
    .page .inner-table td {
      border: none !important;
      padding: 1px;
      height: auto !important;
      max-height: none !important;
      line-height: 1.3 !important;
      font-size: 8px !important;
    }
    .page .inner-table .dotted-line {
      border-bottom: 1px dotted #000 !important;
    }
    .page .mt-neg {
      margin-top: -1px !important;
    }
    @media print {
      .page {
        padding: 5px !important;
        margin: 0 !important;
        page-break-after: always !important;
        page-break-inside: avoid !important;
      }
    }
  </style>

  <h1 class="title">การ์ดรายละเอียดรถยนต์</h1>

