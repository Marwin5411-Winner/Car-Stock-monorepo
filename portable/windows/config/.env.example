# VBeyond portable Windows — copy to config\.env and edit

DATABASE_URL=postgresql://postgres:CHANGE_ME@127.0.0.1:5432/car_stock?schema=public
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
PORT=3001
NODE_ENV=production

# Same host:port as users open in the browser
CORS_ORIGIN=http://localhost:3001

# Portable runtime
VB_HOME=
UPDATER_MODE=portable
STATIC_DIR=public

# Update channel (release zip feed)
UPDATE_CHANNEL=stable
UPDATE_FEED_URL=
# Optional: https://github.com/YOUR_ORG/Car-Stock-monorepo/releases/latest/download/feed.json
AUTO_UPDATE=false
KEEP_RELEASES=3

# Optional PDF (Chrome / Edge)
# CHROMIUM_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
